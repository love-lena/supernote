# Copy this file to .env and fill it in. .env is gitignored — never commit it.

# Account the Manta MCP server uses to log into the cloud (your device account).
SUPERNOTE_EMAIL=you@supernote.local
SUPERNOTE_PASSWORD=change-me

# Optional: require this bearer token on the MCP /mcp endpoint (defense in depth
# on top of the tailnet). Leave blank to rely on the tailnet as the boundary.
MANTA_MCP_BEARER=

# Host path for the cloud's data dir (SQLite DB + blobs + config.yaml).
# Defaults to ./supernote-data beside the compose file. Point it at wherever you
# copied the old host's /data, e.g. /srv/supernote-data.
SUPERNOTE_DATA_DIR=./supernote-data

# Host interface to publish 8080/9000 on. 0.0.0.0 = all interfaces (default).
# Set to the host's tailscale IP (100.x.y.z) to expose ONLY to the tailnet.
BIND_ADDR=0.0.0.0
